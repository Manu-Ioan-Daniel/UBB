<Window x:Class="CSharpLab_3.views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Main" Height="250" Width="400"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Search" Click="HandleSearch" Margin="5,0"/>
            <Button Content="Modify" Click="HandleModify" Margin="5,0"/>
            <Button Content="Reservation" Click="HandleReservation" Margin="5,0"/>
            <Button Content="Logout" Click="HandleLogout" Margin="5,0"/>
        </StackPanel>
        <DataGrid x:Name="CoursesTable" AutoGenerateColumns="False" IsReadOnly="True" ColumnWidth = "*">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding DepartureDateTime}"/>
                <DataGridTextColumn Header="Destination" Binding="{Binding Destination}"/>
                <DataGridTextColumn Header="Available Seats" Binding="{Binding AvailableSeats}"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>