<Window x:Class="CSharpLab_3.views.ReservationFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Make Reservation" Height="180" Width="300"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBox x:Name="ClientNameField" Margin="0,5"/>
        <TextBox x:Name="NoSeatsField" Margin="0,5"/>
        <Button Content="Confirm" Click="HandleConfirm" Margin="0,10"/>
    </StackPanel>
</Window>