<Window x:Class="CSharpLab_3.views.SearchFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search" Height="250" Width="390"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment = "Center" Margin="0,0,0,10">
            <DatePicker x:Name="DatePicker" Margin="0,0,5,0"/>
            <TextBox x:Name="DepartureHourField" Width="80" Margin="0,0,5,0"/>
            <TextBox x:Name="DestinationField" Width="120" Margin="0,0,5,0"/>
            <Button Content="Search" Click="HandleSearch"/>
        </StackPanel>
        <DataGrid x:Name="SeatsTable" AutoGenerateColumns="False" IsReadOnly="True" ColumnWidth = "*">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Seat No" Binding="{Binding SeatNo}"/>
                <DataGridTextColumn Header="Reserved By" Binding="{Binding ClientName}"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>