<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="010-create-projects-table" author="admin">
        <createTable tableName="projects">
            <column name="id" type="SERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="start_date" type="DATE"/>
            <column name="materie_id" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="projects"
                baseColumnNames="materie_id"
                referencedTableName="materii"
                referencedColumnNames="id"
                constraintName="fk_projects_materii"
                onDelete="CASCADE"/>

        <rollback>
            <dropTable tableName="projects"/>
        </rollback>
    </changeSet>

</databaseChangeLog>

