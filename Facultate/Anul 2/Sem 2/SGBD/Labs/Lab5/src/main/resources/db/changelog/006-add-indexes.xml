<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="013-add-indexes-profesori" author="admin">
        <comment>Create indexes on profesori(materie_id) and profesori(email) to improve lookup performance</comment>


        <createIndex indexName="idx_profesori_materie" tableName="profesori">
            <column name="materie_id"/>
        </createIndex>

        <createIndex indexName="idx_profesori_email" tableName="profesori">
            <column name="email"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_profesori_materie" tableName="profesori"/>
            <dropIndex indexName="idx_profesori_email" tableName="profesori"/>
        </rollback>
    </changeSet>

</databaseChangeLog>

