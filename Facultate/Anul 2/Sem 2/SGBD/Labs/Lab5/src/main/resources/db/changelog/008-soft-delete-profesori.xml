<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="015-soft-delete-profesori-columns" author="admin">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="profesori"/>
        </preConditions>

        <addColumn tableName="profesori">
            <column name="is_deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="profesori">
            <column name="deleted_at" type="TIMESTAMP"/>
        </addColumn>

        <addColumn tableName="profesori">
            <column name="deleted_by" type="VARCHAR(100)"/>
        </addColumn>

        <createIndex indexName="idx_profesori_is_deleted" tableName="profesori">
            <column name="is_deleted"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_profesori_is_deleted" tableName="profesori"/>
            <dropColumn tableName="profesori" columnName="deleted_by"/>
            <dropColumn tableName="profesori" columnName="deleted_at"/>
            <dropColumn tableName="profesori" columnName="is_deleted"/>
        </rollback>
    </changeSet>

</databaseChangeLog>

