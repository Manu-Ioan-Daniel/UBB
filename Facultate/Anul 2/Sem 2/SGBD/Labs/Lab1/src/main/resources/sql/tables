CREATE TABLE materii(
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    credits INT NOT NULL
);

CREATE TABLE studenti(
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    age INT NOT NULL
);

CREATE TABLE profesori(
    id SERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    age INT NOT NULL,
    email VARCHAR(255) NOT NULL,
    materie_id INT FOREIGN KEY REFERENCES materii(id) ON DELETE CASCADE,
);
CREATE TABLE note_studenti(
    student_id INT FOREIGN KEY REFERENCES studenti(id) ON DELETE CASCADE,
    materie_id INT FOREIGN KEY REFERENCES materii(id) ON DELETE CASCADE,
    nota BIGINT NOT NULL,
    PRIMARY KEY(student_id, materie_id)
);

